interval: {{interval}}
resource.tracer:
  enabled: {{enable_request_tracer}}
  filename: "../../logs/cel/http-request-trace-*.ndjson"
  maxbackups: 5
{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}
{{#if ssl}}
resource.ssl: {{ssl}}
{{/if}}
{{#if http_client_timeout}}
resource.timeout: {{http_client_timeout}}
{{/if}}
resource.url: {{url}}
state:
  application_key: {{application_key}}
  application_secret: {{application_secret}}
  consumer_key: {{consumer_key}}
redact:
  fields:
    - application_secret
    - consumer_key
    - cursor.creds.application_secret
    - cursor.creds.consumer_key
# This program's queue-draining phase (Phase D) processes exactly one queued past/planned
# intervention detail fetch per evaluation, and the listing phase (Phase C) makes one list call
# per server per kind (past, planned) per evaluation. Accounts with a large fleet of servers
# and/or a high volume of historical interventions can therefore need well more than the
# default 1000 evaluations to complete a single sweep; raise the cap so a large fleet doesn't
# have its poll cycle silently truncated mid-sweep.
max_executions: 5000
program: |-
  // Phase A: calibrate the clock offset against OVH server time (once, cached in cursor.offset)
  // and persist the credentials into cursor.creds -- state.application_key/application_secret/
  // consumer_key are only seeded from config on the very first evaluation; cursor is the only
  // state the framework carries forward across periodic ticks, so credentials must live there.
  !has(state.?cursor.offset) ?
    state.with(
      request("GET", state.url.trim_right("/") + "/auth/time").do_request().as(resp,
        (resp.StatusCode == 200) ?
          {
            "events": [{"retry": true}],
            "cursor": {
              "offset": int(resp.Body.decode_json()) - int(now),
              "creds": {
                "application_key": state.application_key,
                "application_secret": state.application_secret,
                "consumer_key": state.consumer_key,
              },
            },
            "want_more": true,
          }
        :
          {
            "events": {
              "error": {
                "code": string(resp.StatusCode),
                "id": string(resp.Status),
                "message": "GET /auth/time: " + ((size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)),
              },
            },
            "want_more": false,
          }
      )
    )
  :
    state.cursor.creds.as(creds,
      (size(state.cursor.?queue.orValue([])) > 0) ?
        // Phase D: pop the front of the pending-detail queue and fetch one intervention's
        // (past or planned) detail. item.planned distinguishes the two endpoint families.
        state.cursor.queue[0].as(item,
          {
            "kind": item.planned ? "plannedIntervention" : "intervention",
            "ts": int(now) + int(state.cursor.offset),
          }.as(ctx,
            (state.url.trim_right("/") + "/dedicated/server/" + item.service + "/" + ctx.kind + "/" + string(item.id)).as(path,
              state.with(
                request("GET", path).with(
                  {
                    "Header": {
                      "X-Ovh-Application": [creds.application_key],
                      "X-Ovh-Consumer": [creds.consumer_key],
                      "X-Ovh-Timestamp": [string(ctx.ts)],
                      "X-Ovh-Signature": [
                        "$1$" + bytes(
                          [creds.application_secret, creds.consumer_key, "GET", path, "", string(ctx.ts)].join("+")
                        ).sha1().hex(),
                      ],
                      "Accept": ["application/json"],
                    },
                  }
                ).do_request().as(resp,
                  (resp.StatusCode == 200) ?
                    {
                      "events": [
                        {
                          "message": resp.Body.decode_json().with(
                            {"serviceName": item.service, "planned": item.planned}
                          ).encode_json(),
                        },
                      ],
                      "cursor": state.cursor.with(
                        {
                          "queue": tail(state.cursor.queue, 1),
                          // Bounded dedup: intervention IDs are monotonically increasing longs
                          // (per the API research brief), so tracking only the highest seen ID
                          // per server/kind -- rather than an ever-growing list of every ID ever
                          // seen -- is sufficient to never re-emit an already-seen intervention,
                          // and keeps cursor.seen at a fixed size for the agent's lifetime.
                          "seen": state.cursor.?seen.orValue({}).with(
                            {
                              item.service: state.cursor.?seen[?item.service].orValue(
                                {"past": 0, "planned": 0}
                              ).with(
                                item.planned ?
                                  {"planned": [item.id, state.cursor.?seen[?item.service].planned.orValue(0)].max()}
                                :
                                  {"past": [item.id, state.cursor.?seen[?item.service].past.orValue(0)].max()}
                              ),
                            }
                          ),
                        }
                      ),
                      "want_more": true,
                    }
                  :
                    {
                      "events": {
                        "error": {
                          "code": string(resp.StatusCode),
                          "id": string(resp.Status),
                          "message": "GET " + ctx.kind + " detail: " + ((size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)),
                        },
                      },
                      "want_more": false,
                    }
                )
              )
            )
          )
        )
      : !has(state.?cursor.servers) ?
        // Phase B: no active sweep in progress -- list owned dedicated servers and start one.
        (int(now) + int(state.cursor.offset)).as(ts,
          state.with(
            request("GET", state.url.trim_right("/") + "/dedicated/server").with(
              {
                "Header": {
                  "X-Ovh-Application": [creds.application_key],
                  "X-Ovh-Consumer": [creds.consumer_key],
                  "X-Ovh-Timestamp": [string(ts)],
                  "X-Ovh-Signature": [
                    "$1$" + bytes(
                      [
                        creds.application_secret,
                        creds.consumer_key,
                        "GET",
                        state.url.trim_right("/") + "/dedicated/server",
                        "",
                        string(ts),
                      ].join("+")
                    ).sha1().hex(),
                  ],
                  "Accept": ["application/json"],
                },
              }
            ).do_request().as(resp,
              (resp.StatusCode == 200) ?
                {
                  "events": [{"retry": true}],
                  "cursor": state.cursor.with(
                    {
                      "servers": resp.Body.decode_json(),
                      "idx": 0,
                      "listPhase": "past",
                    }
                  ),
                  "want_more": true,
                }
              :
                {
                  "events": {
                    "error": {
                      "code": string(resp.StatusCode),
                      "id": string(resp.Status),
                      "message": "GET /dedicated/server: " + ((size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)),
                    },
                  },
                  "want_more": false,
                }
            )
          )
        )
      : (int(state.cursor.idx) < size(state.cursor.servers)) ?
        // Phase C: list intervention IDs for the current server -- past first, then planned --
        // queue up any not already seen, then advance either the list sub-phase or the server index.
        {
          "idx": int(state.cursor.idx),
          "service": state.cursor.servers[int(state.cursor.idx)],
          "isPlanned": state.cursor.listPhase == "planned",
          "kind": (state.cursor.listPhase == "planned") ? "plannedIntervention" : "intervention",
          "ts": int(now) + int(state.cursor.offset),
        }.as(ctx,
          (state.url.trim_right("/") + "/dedicated/server/" + ctx.service + "/" + ctx.kind).as(path,
            state.with(
              request("GET", path).with(
                {
                  "Header": {
                    "X-Ovh-Application": [creds.application_key],
                    "X-Ovh-Consumer": [creds.consumer_key],
                    "X-Ovh-Timestamp": [string(ctx.ts)],
                    "X-Ovh-Signature": [
                      "$1$" + bytes(
                        [creds.application_secret, creds.consumer_key, "GET", path, "", string(ctx.ts)].join("+")
                      ).sha1().hex(),
                    ],
                    "Accept": ["application/json"],
                  },
                }
              ).do_request().as(resp,
                (resp.StatusCode == 200) ?
                  {
                    "events": [{"retry": true}],
                    "cursor": state.cursor.with(
                      {
                        "idx": ctx.isPlanned ? (ctx.idx + 1) : ctx.idx,
                        "listPhase": ctx.isPlanned ? "past" : "planned",
                        "queue": resp.Body.decode_json().filter(id,
                          id > (
                            ctx.isPlanned ?
                              state.cursor.?seen[?ctx.service].planned.orValue(0)
                            :
                              state.cursor.?seen[?ctx.service].past.orValue(0)
                          )
                        ).map(id, {"service": ctx.service, "id": id, "planned": ctx.isPlanned}),
                      }
                    ),
                    "want_more": true,
                  }
                :
                  {
                    "events": {
                      "error": {
                        "code": string(resp.StatusCode),
                        "id": string(resp.Status),
                        "message": "GET " + ctx.kind + " list: " + ((size(resp.Body) != 0) ? string(resp.Body) : string(resp.Status)),
                      },
                    },
                    "want_more": false,
                  }
              )
            )
          )
        )
      :
        // Phase E: sweep complete -- clear the transient sweep state and pause until the next interval.
        {
          "events": [{"retry": true}],
          "cursor": state.cursor.drop(["servers", "idx", "listPhase"]),
          "want_more": false,
        }
    )
tags:
{{#if preserve_original_event}}
  - preserve_original_event
{{/if}}
{{#each tags as |tag|}}
  - {{tag}}
{{/each}}
{{#contains "forwarded" tags}}
publisher_pipeline.disable_host: true
{{/contains}}
processors:
- drop_event.when.equals.retry: true
{{#if processors}}
{{processors}}
{{/if}}
