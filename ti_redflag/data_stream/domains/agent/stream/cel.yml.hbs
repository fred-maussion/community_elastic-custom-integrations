interval: {{interval}}
resource.url: {{url}}

state:
  url: {{url}}

program: |-
  state.with(
    request(
      "GET",
      state.url
    ).do_request().as(resp,
      (resp.StatusCode == 200) ? dyn({
        "events": string(resp.Body)
          .split('\n')
          .filter(line, line != '' && !line.startsWith('#'))
          .map(domain, {"message": domain})
      }) : dyn({
        "events": {
          "error": {
            "message": "GET " + state.url + ": " + string(resp.StatusCode)
          }
        }
      })
    )
  )

{{#if tags}}
tags:
{{#each tags as |tag|}}
- {{tag}}
{{/each}}
{{/if}}

{{#if timeout}}
resource.timeout: {{timeout}}
{{/if}}

{{#if proxy_url}}
resource.proxy_url: {{proxy_url}}
{{/if}}